{
    "private": true,
    "type": "module",
    "scripts": {
        "build:admin": "vite build --config vite.admin.config.ts",
        "build": "npm run build:admin && vite build",
        "dev:admin": "vite --config vite.admin.config.ts",
        "dev": "vite dev",

        "lint:css": "stylelint 'resources/assets/**/*.scss'",
        "lint:css:fix": "stylelint 'resources/assets/**/*.scss' --fix",

        "lint:js": "eslint resources/assets/js --ext .ts,.js",
        "lint:js:fix": "eslint resources/assets/js --ext .ts,.js --fix",

        "lint": "npm run lint:css && npm run lint:js",
        "lint:fix": "npm run lint:css:fix && npm run lint:js:fix",

        "prettier": "prettier resources/assets --check",
        "prettier:fix": "prettier resources/assets --write"
    },
    "devDependencies": {
        "@shufo/prettier-plugin-blade": "^1.16.1",
        "@tailwindcss/forms": "^0.5.10",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "^24.7.1",
        "autoprefixer": "^10.4.21",
        "chalk": "^5.6.2",
        "cropperjs": "^2.0.1",
        "dotenv": "^17.2.3",
        "eslint": "^9.37.0",
        "highlight.js": "^11.11.1",
        "laravel-vite-plugin": "^2.0",
        "normalize.css": "^8.0.1",
        "postcss-nesting": "^13.0.2",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.6.2",
        "sass": "^1.93.2",
        "stylelint-config-standard-scss": "^16.0.0",
        "svgo": "^4.0.0",
        "tailwindcss": "^3.4.3",
        "typescript-eslint": "^8.46.0",
        "typescript": "^5.9.3",
        "vite-plugin-static-copy": "^3.1.3",
        "vite-svg-loader": "^5.1.0",
        "vite": "^7.1"
    },
    "dependencies": {
        "a11y-dialog": "^8.1.4",
        "axios": "^1.12.2",
        "flatpickr": "^4.6.13",
        "tiny-slider": "^2.9.4"
    }
}
